# authd secrets. Copy to .env for local dev (`node --env-file=.env server.ts`).
# Everything non-sensitive lives in config.local.yaml / config.prod.yaml —
# these are only the values the config references via ${VAR}.

# Signing/encryption key. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me

# GitHub OAuth — the only sign-in method (required). Create a GitHub OAuth app
# with callback http://localhost:8787/api/auth/callback/github
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me
