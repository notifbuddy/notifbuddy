# authd secrets. Copy to .env for local dev (`node --env-file=.env server.ts`).
# Non-sensitive settings: config/authd/${NB_ENV}.yaml + config/featureflags/${NB_ENV}.yaml
# (default NB_ENV=local). These are only the values the config references via ${VAR}.

# Optional: NB_ENV=local|prod|preview  (selects which YAML files to load)

# Signing/encryption key. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me

# GitHub OAuth — required. Local callback:
#   http://localhost:8787/api/auth/callback/github
# Prod/preview share one app; callback is always:
#   https://auth.notifbuddy.com/api/auth/callback/github
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me

# Only needed for NB_ENV=prod|preview (oAuthProxy). Same value in Infisical /auth.
# OAUTH_PROXY_SECRET=
