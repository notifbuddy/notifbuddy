# authd configuration. Copy to .env for local dev (server.js reads the real
# environment; use `node --env-file=.env server.js` or export these).

# Postgres for auth data (users, sessions, orgs, invitations, rate limits).
# Local dev: a dedicated database on the same homebrew postgres as the backend.
DATABASE_URL=postgres://localhost/authd

# Secret for signing/encryption. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me

# Public base URL of this service (prod: https://auth.notifbuddy.com).
BETTER_AUTH_URL=http://localhost:8787

# Origins allowed to call authd from the browser (the dashboard SPA).
TRUSTED_ORIGINS=http://localhost:5173

# Prod only: share the session cookie across subdomains so api.<zone> sees it.
# COOKIE_DOMAIN=.notifbuddy.com

# GitHub social login — the only sign-in method (required). Create a GitHub
# OAuth app with callback <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me

# Outbound email (optional; console-logged when unset). Both or neither.
# RESEND_API_KEY=
# EMAIL_FROM=notifbuddy <auth@notifbuddy.com>
