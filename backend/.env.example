# Environment variables referenced by backend/config.local.yaml.
#
# config.local.yaml resolves `$VAR` / `${VAR}` references at startup; the SECRET fields
# (api_key, cookie_password) reference the variables below so real secrets never
# live in the committed YAML. Copy this to backend/.env and fill in real values:
#   cp backend/.env.example backend/.env
# The backend auto-loads backend/.env at startup (godotenv), so `make dev-backend`
# picks it up with no shell setup. Real env vars, if already set, take precedence.

# --- Auth ---
# Sessions come from authd (the Better Auth service, ../authd). No backend
# auth secrets: the backend validates sessions by forwarding the browser's
# cookie to authd (auth.base_url in config.local.yaml). See authd/README.md
# for its own .env.

# --- Database (for integrations) ---

# Postgres connection string. Integrations (Slack/Linear) need it; if unset, the
# integration endpoints report "not configured". Create a local `xolo` database
# (or use docker-compose) and point at it.
DATABASE_URL=postgres://localhost:5432/xolo?sslmode=disable

# --- Integration token encryption ---

# Base64-encoded 32-byte key used to encrypt integration tokens at rest
# (encryption.provider=local). Generate with:  head -c 32 /dev/urandom | base64
# Leave unset for an ephemeral dev key (tokens won't survive a restart).
INTEGRATION_ENC_KEY=replace_with_base64_32_byte_key

# --- Slack app (for the Slack integration) ---
SLACK_CLIENT_ID=0000000000000.0000000000000
SLACK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Linear OAuth app (for the Linear integration) ---
# Create an OAuth application in Linear (Settings → API → OAuth applications),
# set the redirect URL to http://localhost:8080/integrations/linear/callback.
LINEAR_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret — shown when you enable webhooks on the Linear OAuth
# app (or create a webhook). Verifies the Linear-Signature header. Empty disables
# signature verification (local testing only).
LINEAR_WEBHOOK_SECRET=replace_with_the_linear_webhook_signing_secret

# --- Cloudflare Workers AI (NotifBuddy intent parsing) ---
# Powers create-channel/close-channel/no-action classification of @notifbuddy
# mentions. Create an API token scoped to Workers AI. Empty disables parsing
# (every comment resolves to "no-action"). The model id lives in config.local.yaml.
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_API_TOKEN=replace_with_a_workers_ai_api_token

# Note: non-sensitive settings (addr, CORS origin, redirect/callback URLs,
# login_provider, post_login_url, slack.scopes,
# and the workspace/user scope lists) live in backend/config.local.yaml, not here. To pull any of them from the environment,
# set that YAML field to a `$VAR` reference and define the variable here.

# --- Stripe billing (Pro plan) ---
# Restricted API key (rk_test_...) — Stripe dashboard → Developers → API keys →
# Create restricted key, with write on Customers, Checkout Sessions,
# Subscriptions, and Billing Portal. Empty disables checkout (trial still works).
STRIPE_API_KEY=rk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret. Locally: `stripe listen --latest --forward-to
# localhost:8080/billing/stripe/webhook` prints a whsec_... value (--latest is
# required — stripe-go rejects events rendered with older API versions).
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- WorkOS webhooks (membership events -> billing seat sync) ---
# WorkOS dashboard → Webhooks → endpoint <backend-url>/auth/workos/webhook,
# events organization_membership.created/updated/deleted. Empty disables the
# endpoint (seat counts then true-up on renewal/billing-page loads).
WORKOS_WEBHOOK_SECRET=replace_with_the_workos_webhook_signing_secret

# --- Public base URL (Slack image asset proxy) ---
# Internet-reachable base URL of this backend — your personal dev tunnel
# (e.g. a cloudflared tunnel pointing at localhost:8080). Slack fetches the
# signed /integrations/linear/asset/... links from here to render mirrored
# Linear images inline. Empty disables inline image mirroring (loudly; the
# comment keeps the markdown link instead).
PUBLIC_BASE_URL=https://your-dev-tunnel.example.com
