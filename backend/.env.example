# Environment variables referenced by backend/config.yaml.
#
# config.yaml resolves `$VAR` / `${VAR}` references at startup; the SECRET fields
# (api_key, cookie_password) reference the variables below so real secrets never
# live in the committed YAML. Copy this to backend/.env and fill in real values:
#   cp backend/.env.example backend/.env
# The backend auto-loads backend/.env at startup (godotenv), so `make dev-backend`
# picks it up with no shell setup. Real env vars, if already set, take precedence.

# --- Secrets (referenced by config.yaml; required) ---

# Server-side WorkOS API key (sk_...). Keep secret.
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret that seals the session cookie. MUST be >= 32 chars.
# Generate one with:  openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace_with_a_random_string_at_least_32_chars

# --- Public identifier (referenced by config.yaml) ---

# WorkOS application client ID (client_...). Public, not a secret — you may also
# inline it directly in config.yaml instead of referencing it here.
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Database (for integrations) ---

# Postgres connection string. Integrations (GitHub/Slack) need it; if unset, the
# integration endpoints report "not configured". Create a local `xolo` database
# (or use docker-compose) and point at it.
DATABASE_URL=postgres://localhost:5432/xolo?sslmode=disable

# --- Integration token encryption ---

# Base64-encoded 32-byte key used to encrypt integration tokens at rest
# (encryption.provider=local). Generate with:  head -c 32 /dev/urandom | base64
# Leave unset for an ephemeral dev key (tokens won't survive a restart).
INTEGRATION_ENC_KEY=replace_with_base64_32_byte_key

# --- GitHub App (for the GitHub integration) ---
# Register a GitHub App, then fill these in. app_slug/app_id go in config.yaml.
GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The App's PEM private key. For multi-line values in .env, wrap in quotes with \n,
# or point DATABASE-style at a file via your process manager.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Webhook HMAC secret — must match the secret set on the GitHub App's webhook.
# Empty disables signature verification (local testing only).
GITHUB_WEBHOOK_SECRET=replace_with_the_app_webhook_secret

# --- Slack app (for the Slack integration) ---
SLACK_CLIENT_ID=0000000000000.0000000000000
SLACK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Linear OAuth app (for the Linear integration) ---
# Create an OAuth application in Linear (Settings → API → OAuth applications),
# set the redirect URL to http://localhost:8080/integrations/linear/callback.
LINEAR_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret — shown when you enable webhooks on the Linear OAuth
# app (or create a webhook). Verifies the Linear-Signature header. Empty disables
# signature verification (local testing only).
LINEAR_WEBHOOK_SECRET=replace_with_the_linear_webhook_signing_secret

# Note: non-sensitive settings (addr, CORS origin, redirect/callback URLs,
# login_provider, post_login_url, github.app_slug, github.app_id, slack.scopes)
# live in backend/config.yaml, not here. To pull any of them from the environment,
# set that YAML field to a `$VAR` reference and define the variable here.
