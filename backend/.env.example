# Environment variables referenced by backend/config.yaml.
#
# config.yaml resolves `$VAR` / `${VAR}` references at startup; the SECRET fields
# (api_key, cookie_password) reference the variables below so real secrets never
# live in the committed YAML. Copy this to backend/.env and fill in real values:
#   cp backend/.env.example backend/.env
# The backend auto-loads backend/.env at startup (godotenv), so `make dev-backend`
# picks it up with no shell setup. Real env vars, if already set, take precedence.

# --- Secrets (referenced by config.yaml; required) ---

# Server-side WorkOS API key (sk_...). Keep secret.
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret that seals the session cookie. MUST be >= 32 chars.
# Generate one with:  openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace_with_a_random_string_at_least_32_chars

# --- Public identifier (referenced by config.yaml) ---

# WorkOS application client ID (client_...). Public, not a secret — you may also
# inline it directly in config.yaml instead of referencing it here.
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxx

# Note: non-sensitive settings (addr, CORS origin, redirect URI, login_provider,
# post_login_url) live in backend/config.yaml, not here. To pull any of them from
# the environment, set that YAML field to a reference, e.g.
#   login_provider: $WORKOS_LOGIN_PROVIDER
# and define the variable here. A literal YAML value is used as-is.
