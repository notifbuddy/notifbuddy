# Runner image for the black-box e2e suite. Build context is the backend/ dir
# (so it shares the backend Go module); it compiles and runs the e2e-tagged
# tests against the server named by E2E_BASE_URL.
FROM golang:1.25.8-alpine

# git + TLS roots for module downloads; nothing else needed (pure-Go deps).
RUN apk add --no-cache git ca-certificates

WORKDIR /src

# Cache modules first.
COPY go.mod go.sum ./
RUN go mod download

# Then the source (includes ./e2e).
COPY . .

# The suite skips itself unless E2E_BASE_URL is set (see TestMain). -count=1
# disables the test cache so every `up` re-runs against the live server.
CMD ["go", "test", "-tags", "e2e", "-count=1", "-v", "./e2e/..."]
