# Scoped ignore for the repo-root build context of Dockerfile.ui. Only
# frontend/, shared/, and config/ are needed; everything else just bloats
# the context.
*
!frontend
!shared
!config
frontend/node_modules
frontend/build
frontend/.svelte-kit
frontend/playwright-report
frontend/test-results
**/node_modules
**/.env
**/.env.*
.git
